<% layout("/layouts/boilerplate") %>

<link rel="stylesheet" href="/css/profile.css">

<div class="container my-5">
    <div class="row g-4">
        <!-- LEFT COLUMN: PUBLIC CARD -->
        <div class="col-lg-4 col-12">
            <div class="card profile-sidebar p-4 shadow-sm text-center">
                <!-- Avatar image -->
                <div class="profile-avatar-container mb-3">
                    <img src="<%= (user.avatar && user.avatar.url) ? user.avatar.url : 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=250&q=80' %>" alt="avatar" class="profile-avatar">
                </div>
                
                <h3 class="fw-bold mb-1"><%= user.username %></h3>
                <p class="text-muted small"><%= user.profession || "Profession not set" %> <%= user.college ? 'at ' + user.college : '' %></p>
                
                <!-- Verification Badges -->
                <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
                    <% if (user.verification && user.verification.emailVerified) { %>
                        <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle rounded-pill px-2 py-1"><i class="fa-solid fa-envelope-circle-check"></i> Email Verified</span>
                    <% } %>
                    <% if (user.verification && user.verification.phoneVerified) { %>
                        <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle rounded-pill px-2 py-1"><i class="fa-solid fa-phone-flip"></i> Phone Verified</span>
                    <% } %>
                    <% if (user.verification && user.verification.idVerified) { %>
                        <span class="badge bg-info bg-opacity-10 text-info border border-info-subtle rounded-pill px-2 py-1"><i class="fa-solid fa-id-card"></i> ID Verified</span>
                    <% } %>
                    <% if (user.verification && user.verification.superhost) { %>
                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle rounded-pill px-2 py-1"><i class="fa-solid fa-medal"></i> Super Host</span>
                    <% } %>
                </div>

                <div class="text-start border-top pt-3">
                    <p class="mb-2"><i class="fa-solid fa-user-clock text-muted me-2"></i> Joined: <%= new Date(user.joinedDate).toLocaleDateString("en-IN", {year: "numeric", month: "long"}) %></p>
                    <% if (user.city || user.country) { %>
                        <p class="mb-2"><i class="fa-solid fa-location-dot text-muted me-2"></i> Live in: <%= [user.city, user.country].filter(Boolean).join(", ") %></p>
                    <% } %>
                </div>

                <!-- Languages Spoken -->
                <div class="text-start border-top pt-3 mt-2">
                    <h6 class="fw-bold">Languages Spoken</h6>
                    <% if (user.languages && user.languages.length > 0) { %>
                        <div class="d-flex flex-wrap gap-2 mt-1">
                            <% user.languages.forEach(lang => { %>
                                <span class="badge bg-dark rounded-pill px-2 py-1"><%= lang %></span>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <p class="text-muted small mb-0">No languages specified</p>
                    <% } %>
                </div>


            </div>
        </div>

        <!-- RIGHT COLUMN: BIO, LISTINGS, REVIEWS -->
        <div class="col-lg-8 col-12">
            <!-- Bio Card -->
            <div class="card profile-card p-4 shadow-sm mb-4">
                <h4 class="fw-bold mb-3">About @<%= user.username %></h4>
                <% if (user.bio) { %>
                    <p class="text-dark mb-0" style="line-height: 1.6; white-space: pre-wrap;"><%= user.bio %></p>
                <% } else { %>
                    <p class="text-muted mb-0">No description provided yet.</p>
                <% } %>
            </div>

            <!-- PUBLIC STATISTICS CARDS -->
            <div class="card profile-card p-4 shadow-sm mb-4">
                <h4 class="fw-bold mb-3"><i class="fa-solid fa-chart-bar text-danger me-2"></i> Host Statistics</h4>
                <div class="row row-cols-md-3 row-cols-1 g-3">
                    <div class="col">
                        <div class="stat-box p-3 text-center">
                            <h2 class="fw-bold text-dark mb-0"><%= hostStats.totalListings %></h2>
                            <small class="text-muted">Properties Listed</small>
                        </div>
                    </div>
                    <div class="col">
                        <div class="stat-box p-3 text-center">
                            <h2 class="fw-bold text-dark mb-0"><%= hostStats.avgRating %> ★</h2>
                            <small class="text-muted">Average Rating</small>
                        </div>
                    </div>
                    <div class="col">
                        <div class="stat-box p-3 text-center">
                            <h2 class="fw-bold text-dark mb-0"><%= hostStats.guestsHosted %></h2>
                            <small class="text-muted">Guests Hosted</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PUBLIC LISTINGS GRID -->
            <div class="card profile-card p-4 shadow-sm mb-4">
                <h4 class="fw-bold mb-3"><i class="fa-solid fa-hotel text-primary me-2"></i> Listings</h4>
                <% if (publicListings.length === 0) { %>
                    <p class="text-muted mb-0">No properties listed by this host.</p>
                <% } else { %>
                    <div class="row row-cols-md-2 row-cols-1 g-3">
                        <% publicListings.forEach(listing => { %>
                            <div class="col">
                                <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden">
                                    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image" style="height: 160px; object-fit: cover;">
                                    <div class="card-body p-3">
                                        <h6 class="fw-bold mb-1 text-truncate"><%= listing.title %></h6>
                                        <p class="text-muted mb-2 small"><i class="fa-solid fa-location-dot me-1"></i> <%= listing.location %>, <%= listing.country %></p>
                                        <div class="d-flex justify-content-between align-items-center mt-2">
                                            <span class="text-dark fw-bold small">
                                                <% if (listing.listingType === 'pg') { %>
                                                    ₹<%= listing.pgDetails.monthlyRent.toLocaleString("en-IN") %>/mo
                                                <% } else { %>
                                                    ₹<%= listing.price.toLocaleString("en-IN") %>/night
                                                <% } %>
                                            </span>
                                            <a href="/listings/<%= listing._id %>" class="btn btn-outline-danger btn-sm rounded-pill py-1 px-3" style="font-size: 0.75rem;">View Listing</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>

            <!-- PUBLIC REVIEWS RECEIVED -->
            <div class="card profile-card p-4 shadow-sm">
                <h4 class="fw-bold mb-3"><i class="fa-solid fa-comments text-info me-2"></i> Reviews Received</h4>
                <div class="list-group list-group-flush">
                    <% if (reviewsReceived.length === 0) { %>
                        <div class="text-center py-4 text-muted small">No reviews received yet.</div>
                    <% } %>
                    <% reviewsReceived.forEach(review => { %>
                        <div class="list-group-item py-3 px-0 border-bottom border-light">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <div class="d-flex align-items-center">
                                    <img src="<%= review.author.avatar ? review.author.avatar.url : 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=80&q=80' %>" alt="avatar" class="rounded-circle me-2" style="width: 32px; height: 32px; object-fit: cover;">
                                    <a href="/users/<%= review.author._id %>" class="text-decoration-none text-dark fw-bold small">@<%= review.author.username %></a>
                                </div>
                                <span class="text-warning small"><%= "★".repeat(review.rating) %><%= "☆".repeat(5-review.rating) %></span>
                            </div>
                            <p class="mb-0 text-muted small"><%= review.comment %></p>
                            <small class="text-muted font-monospace" style="font-size: 0.7rem;"><%= new Date(review.createdAt).toLocaleDateString("en-IN") %></small>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>
