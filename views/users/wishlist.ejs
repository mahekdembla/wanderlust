<% layout("/layouts/boilerplate") %>

<div class="container my-4">
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <h2 class="fw-bold text-dark mb-0">
            <i class="fa-solid fa-heart text-danger me-2"></i>My Wishlist
        </h2>
        <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fs-6">
            <%= listings ? listings.filter(Boolean).length : 0 %> Saved Stays
        </span>
    </div>

    <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-1 g-4 mt-1">
        <% if (!listings || listings.filter(Boolean).length === 0) { %>
            <div class="col-12 text-center py-5">
                <div class="card p-5 border-0 shadow-sm rounded-4 bg-white text-center">
                    <i class="fa-regular fa-heart display-1 text-muted opacity-50 mb-3"></i>
                    <h4 class="fw-bold text-dark">Your wishlist is empty</h4>
                    <p class="text-muted">As you search, tap the heart icon on any stay to save your favorite properties here.</p>
                    <div class="mt-3">
                        <a href="/listings" class="btn btn-danger rounded-pill px-4 py-2 fw-semibold">
                            <i class="fa-solid fa-compass me-2"></i>Explore Stays
                        </a>
                    </div>
                </div>
            </div>
        <% } else { %>
            <% listings.forEach(listing => { 
                if (!listing) return;
            %>
                <div class="col mb-4">
                    <div class="card listing-card position-relative shadow-sm border-0 rounded-4 overflow-hidden h-100 bg-white">
                        <i class="fa-solid fa-heart wishlist-heart saved" data-id="<%= listing._id %>" title="Remove from Wishlist"></i>

                        <a href="/listings/<%= listing._id %>" class="listing-link">
                            <div class="listing-card-img-wrapper position-relative">
                                <img src="<%= (listing.images && listing.images.length > 0) ? listing.images[0].url : (listing.image ? listing.image.url : 'https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=400&q=80') %>" class="card-img-top" style="aspect-ratio: 4/3; object-fit: cover; width: 100%;" alt="<%= listing.title %>" loading="lazy">
                            </div>
                        </a>

                        <div class="card-body p-3 d-flex flex-column justify-content-between">
                            <div>
                                <h6 class="card-title mb-1"><strong><%= listing.title %></strong></h6>
                                <p class="card-text text-muted mb-2 small"><i class="fa-solid fa-location-dot me-1 text-danger"></i><%= listing.location %></p>
                            </div>
                            <div class="card-footer-info d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
                                <span class="price-tag small">
                                    <% if (listing.listingType === "pg") { %>
                                        <strong>₹ <%= listing.pgDetails?.monthlyRent?.toLocaleString("en-IN") %></strong> / month
                                    <% } else { %>
                                        <strong>₹ <%= listing.price?.toLocaleString("en-IN") %></strong> / night
                                    <% } %>
                                </span>
                                <% if (listing.rating) { %>
                                    <span class="badge bg-light text-dark border"><i class="fa-solid fa-star text-warning me-1"></i><%= listing.rating %></span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<script>
    document.querySelectorAll(".wishlist-heart").forEach(icon => {
        icon.addEventListener("click", async (e) => {
            e.stopPropagation();
            e.preventDefault();

            const id = icon.dataset.id;
            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';

            const res = await fetch(`/wishlist/toggle/${id}`, { 
                method: "POST",
                headers: { 
                    "Content-Type": "application/json",
                    "X-CSRF-Token": csrfToken,
                    "X-Requested-With": "XMLHttpRequest"
                }
            });
            const data = await res.json();
            if (data.success) {
                const cardCol = icon.closest(".col");
                if (cardCol) {
                    cardCol.style.transition = "opacity 0.3s ease, transform 0.3s ease";
                    cardCol.style.opacity = "0";
                    cardCol.style.transform = "scale(0.9)";
                    setTimeout(() => cardCol.remove(), 300);
                }
            }
        });
    });
</script>
