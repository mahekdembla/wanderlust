<% layout("/layouts/boilerplate") %>

<h2 class="mt-4"> Wishlist <i class="fa-solid fa-heart saved"></i></h2>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">

    <% if (listings.length === 0) { %>
        <p>No saved listings yet.</p>
    <% } %>

    <% listings.forEach(listing => { 
        if (!listing) return;
    %>

        <div class="col mb-4">
            <div class="card listing-card position-relative shadow-sm border-0 rounded-4 overflow-hidden h-100 bg-white">

                <i class="fa-solid fa-heart wishlist-heart saved" data-id="<%= listing._id %>" style="position: absolute; top: 12px; right: 15px; font-size: 1.8rem; z-index: 10; cursor: pointer;"></i>

                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <img src="<%= (listing.images && listing.images.length > 0) ? listing.images[0].url : (listing.image ? listing.image.url : 'https://media.cntraveler.com/photos/5d112d50c4d7bd806dbc00a4/16:9/w_2239,h_1259,c_limit/airbnb%20luxe.jpg') %>" class="card-img-top" style="height:15rem; object-fit: cover;" alt="<%= listing.title %>">
                </a>

                <div class="card-body p-3">
                    <h6 class="card-title mb-1 text-truncate"><strong><%= listing.title %></strong></h6>
                    <p class="card-text text-muted mb-2 small"><i class="fa-solid fa-location-dot me-1 text-danger"></i><%= listing.location %></p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-dark small">
                            <% if (listing.listingType === "pg") { %>
                                <strong>₹ <%= listing.pgDetails?.monthlyRent?.toLocaleString("en-IN") %></strong> / month
                            <% } else { %>
                                <strong>₹ <%= listing.price?.toLocaleString("en-IN") %></strong> / night
                            <% } %>
                        </span>
                    </div>
                </div>
            </div>
        </div>

    <% }) %>

</div>

<script>
    document.querySelectorAll(".wishlist-heart").forEach(icon => {
        icon.addEventListener("click", async (e) => {
            e.stopPropagation();
            e.preventDefault();

            const id = icon.dataset.id;
            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';

            const res = await fetch(`/wishlist/toggle/${id}`, { 
                method: "POST",
                headers: { "X-CSRF-Token": csrfToken }
            });
            const data = await res.json();
            if (data.success) {
                const cardCol = icon.closest(".col");
                if (cardCol) cardCol.remove();
            }
        });
    });
</script>
