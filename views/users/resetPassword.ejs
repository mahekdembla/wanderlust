<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-6 offset-3">
        <h3 class="mb-3">Reset Password</h3>
        <p class="text-muted">Create a strong new password matching the security criteria.</p>

        <form action="/reset-password/<%= token %>" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="password" class="form-label">New Password</label>
                <input 
                    name="password" 
                    id="password" 
                    type="password" 
                    class="form-control" 
                    required
                />
                <small class="form-text text-muted d-block mt-1">
                    Password must be at least 8 characters long, containing uppercase, lowercase, numbers, and special symbols.
                </small>
                <div class="invalid-feedback">Please enter a new password.</div>
            </div>
            
            <button class="btn btn-danger rounded-pill px-4">Reset Password</button>
        </form>
    </div>
</div>
