<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-6 offset-3">
        <h3 class="mb-3">Forgot Password</h3>
        <p class="text-muted">Enter your email address and we will print a password reset link to the system console.</p>

        <form action="/forgot-password" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="email" class="form-label">Email Address</label>
                <input 
                    name="email" 
                    id="email" 
                    type="email" 
                    class="form-control" 
                    required
                />
                <div class="invalid-feedback">Please enter a valid email address.</div>
            </div>
            
            <button class="btn btn-danger rounded-pill px-4">Send Reset Link</button>
        </form>
    </div>
</div>
