<% layout("/layouts/boilerplate") -%>

<% 
const itineraryVal = typeof itinerary !== 'undefined' ? itinerary : null;
const queryVal = typeof query !== 'undefined' ? query : "";
const matchedStaysVal = typeof matchedStays !== 'undefined' ? matchedStays : [];
%>

<!-- Load PDF Export library -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<style>
    .planner-card {
        border-radius: 1.5rem;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        background: #fff;
        padding: 2.5rem;
        margin-top: 2rem;
    }
    
    .plan-btn {
        background-color: #fe424d;
        color: white;
        border: none;
        border-radius: 25px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        transition: background-color 0.2s ease;
    }
    
    .plan-btn:hover {
        background-color: #e03741;
        color: white;
    }

    .itinerary-container {
        background-color: #fcfcfc;
        border: 1px solid #eaeaea;
        border-radius: 1.25rem;
        padding: 2rem;
        margin-top: 2.5rem;
    }

    /* Style markdown output tables & headings nicely */
    #itineraryHtml table {
        width: 100%;
        margin-bottom: 1rem;
        border-collapse: collapse;
    }
    #itineraryHtml th, #itineraryHtml td {
        padding: 0.75rem;
        border: 1px solid #dee2e6;
    }
    #itineraryHtml th {
        background-color: #f8f9fa;
    }

    /* Loading Spinner Overlay */
    #loadingOverlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.85);
        z-index: 9999;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    .spinner-border-rec {
        width: 3.5rem;
        height: 3.5rem;
        color: #fe424d;
    }
</style>

<div class="row">
    <div class="col-lg-8 offset-lg-2">
        <div class="planner-card">
            <h2 class="fw-bold mb-2 text-center"><i class="fa-solid fa-plane-departure text-danger me-2"></i>AI Trip Planner</h2>
            <p class="text-muted text-center mb-4">Let our AI build your dream itinerary, estimate your budget, and suggest matching stays in seconds.</p>

            <form action="/ai/trip-planner" method="POST" id="plannerForm">
                <!-- CSRF Token -->
                <% if (typeof csrfToken !== 'undefined') { %>
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% } %>
                
                <div class="mb-3">
                    <label for="queryInput" class="form-label fw-semibold">Tell us about your trip plans:</label>
                    <textarea 
                        name="query" 
                        id="queryInput" 
                        class="form-control rounded-3" 
                        rows="3" 
                        placeholder="e.g. I want a 6 day honeymoon trip to Manali under ₹35,000 for 2 guests"
                        required
                    ><%= queryVal %></textarea>
                </div>
                
                <div class="text-center mt-4">
                    <button type="submit" class="plan-btn btn shadow-sm"><i class="fa-solid fa-wand-magic-sparkles me-2"></i>Generate Itinerary</button>
                </div>
            </form>
        </div>

        <% if (itineraryVal) { %>
            <div class="itinerary-container shadow-sm position-relative" id="itineraryPrintArea">
                <!-- Action Buttons Bar -->
                <div class="d-flex justify-content-end gap-2 mb-3 no-print">
                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" id="copyItineraryBtn"><i class="fa-regular fa-copy me-1"></i> Copy</button>
                    <button class="btn btn-sm btn-outline-danger rounded-pill px-3" id="pdfItineraryBtn"><i class="fa-solid fa-file-pdf me-1"></i> PDF</button>
                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3" id="shareItineraryBtn"><i class="fa-solid fa-share-nodes me-1"></i> Share</button>
                </div>

                <h4 class="fw-bold border-bottom pb-2 mb-4 text-dark"><i class="fa-regular fa-calendar-check text-success me-2"></i>Your Custom Itinerary & Travel Plan</h4>
                
                <div id="itineraryHtml" class="text-dark">
                    <!-- Parsed HTML will render here -->
                </div>

                <!-- Hidden source Markdown container -->
                <div id="rawItinerary" class="d-none"><%= itineraryVal %></div>
            </div>
        <% } %>

        <!-- Recommended Listings Section -->
        <% if (itineraryVal && matchedStaysVal && matchedStaysVal.length > 0) { %>
            <h4 class="fw-bold mt-5 mb-3"><i class="fa-solid fa-map-location-dot text-danger me-2"></i>Matched Wanderlust Stays</h4>
            <div class="row row-cols-lg-2 row-cols-md-2 row-cols-sm-1 g-4 mb-5">
                <% matchedStaysVal.forEach(stay => { %>
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden bg-white">
                            <a href="/listings/<%= stay._id %>" class="text-decoration-none">
                                <img 
                                    src="<%= (stay.images && stay.images.length > 0) ? stay.images[0].url : 'https://media.cntraveler.com/photos/5d112d50c4d7bd806dbc00a4/16:9/w_2239,h_1259,c_limit/airbnb%20luxe.jpg' %>" 
                                    class="card-img-top" 
                                    style="height: 12rem; object-fit: cover;" 
                                    alt="<%= stay.title %>"
                                >
                            </a>
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="card-title fw-bold mb-0 text-dark text-truncate" style="max-width: 70%;"><%= stay.title %></h6>
                                    <span class="badge bg-light text-dark border"><i class="fa-solid fa-star text-warning me-1"></i><%= stay.rating || 'N/A' %></span>
                                </div>
                                <p class="text-muted small mb-2"><i class="fa-solid fa-location-dot me-1"></i><%= stay.location %>, <%= stay.country %></p>
                                <p class="fw-bold text-danger mb-3">₹<%= stay.listingType === 'pg' ? (stay.pgDetails?.monthlyRent || 0) + '/mo' : (stay.price || 0) + '/night' %></p>
                                <div class="d-flex gap-2">
                                    <a href="/listings/<%= stay._id %>" class="btn btn-outline-dark btn-sm rounded-pill w-50">Details</a>
                                    <a href="/listings/<%= stay._id %>" class="btn btn-danger btn-sm rounded-pill w-50 text-white">Book Now</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>

<!-- Spinner overlay with rotating smart messages -->
<div id="loadingOverlay">
    <div class="spinner-border spinner-border-rec mb-3" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
    <h5 class="fw-bold text-dark" id="loadingMessage">Analyzing destination...</h5>
    <p class="text-muted small">Wanderlust AI is assembling your custom travel itinerary.</p>
</div>

<script>
    // 1. Submit loading overlays
    document.getElementById("plannerForm").addEventListener("submit", () => {
        document.getElementById("loadingOverlay").style.display = "flex";
        
        const messages = [
            "Analyzing destination constraints...",
            "Searching stays on Wanderlust database...",
            "Matching custom listing filters...",
            "Structuring day-wise plans & sightseeing...",
            "Calculating travel budget breakdowns...",
            "Finalizing tips and packing checklists..."
        ];
        let idx = 0;
        const msgEl = document.getElementById("loadingMessage");
        setInterval(() => {
            idx = (idx + 1) % messages.length;
            if (msgEl) msgEl.textContent = messages[idx];
        }, 2500);
    });

    // 2. Render Markdown on Client side
    document.addEventListener("DOMContentLoaded", () => {
        const rawEl = document.getElementById("rawItinerary");
        const htmlEl = document.getElementById("itineraryHtml");
        if (rawEl && htmlEl) {
            const rawMarkdown = rawEl.textContent;
            htmlEl.innerHTML = DOMPurify.sanitize(marked.parse(rawMarkdown));
        }

        // Action: Copy
        const copyBtn = document.getElementById("copyItineraryBtn");
        if (copyBtn) {
            copyBtn.addEventListener("click", () => {
                const markdown = rawEl.textContent;
                navigator.clipboard.writeText(markdown).then(() => {
                    copyBtn.innerHTML = `<i class="fa-solid fa-check me-1"></i> Copied!`;
                    setTimeout(() => {
                        copyBtn.innerHTML = `<i class="fa-regular fa-copy me-1"></i> Copy`;
                    }, 2000);
                });
            });
        }

        // Action: Share
        const shareBtn = document.getElementById("shareItineraryBtn");
        if (shareBtn) {
            shareBtn.addEventListener("click", () => {
                if (navigator.share) {
                    navigator.share({
                        title: 'My Wanderlust Custom Travel Plan',
                        text: 'Take a look at the custom itinerary I generated!',
                        url: window.location.href
                    });
                } else {
                    navigator.clipboard.writeText(window.location.href).then(() => {
                        shareBtn.innerHTML = `<i class="fa-solid fa-check me-1"></i> Link Copied!`;
                        setTimeout(() => {
                            shareBtn.innerHTML = `<i class="fa-solid fa-share-nodes me-1"></i> Share`;
                        }, 2000);
                    });
                }
            });
        }

        // Action: PDF Download
        const pdfBtn = document.getElementById("pdfItineraryBtn");
        if (pdfBtn) {
            pdfBtn.addEventListener("click", () => {
                const element = document.getElementById("itineraryPrintArea");
                
                // Hide action buttons during download
                const actions = element.querySelector(".no-print");
                if (actions) actions.style.display = "none";

                const opt = {
                    margin:       0.5,
                    filename:     'wanderlust_itinerary.pdf',
                    image:        { type: 'jpeg', quality: 0.98 },
                    html2canvas:  { scale: 2, useCORS: true },
                    jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' }
                };

                html2pdf().set(opt).from(element).save().then(() => {
                    if (actions) actions.style.display = "flex";
                });
            });
        }
    });
</script>
