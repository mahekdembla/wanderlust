<% layout("/layouts/boilerplate") %>

<div class="container my-4">
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <h2 class="fw-bold text-dark mb-0">
            <i class="fa-solid fa-magnifying-glass text-danger me-2"></i>Search Results
        </h2>
        <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fs-6">
            <%= listings ? listings.length : 0 %> Stays Found
        </span>
    </div>

    <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-1 g-4 mt-1">
        <% if (!listings || listings.length === 0) { %>
            <div class="col-12 text-center py-5">
                <div class="card p-5 border-0 shadow-sm rounded-4 bg-white text-center">
                    <i class="fa-solid fa-circle-question display-1 text-muted opacity-50 mb-3"></i>
                    <h4 class="fw-bold text-dark">No matching stays found</h4>
                    <p class="text-muted">Try searching for a different city, country, or keyword.</p>
                    <div class="mt-3">
                        <a href="/listings" class="btn btn-danger rounded-pill px-4 py-2 fw-semibold">
                            <i class="fa-solid fa-compass me-2"></i>Explore All Stays
                        </a>
                    </div>
                </div>
            </div>
        <% } else { %>
            <% listings.forEach(listing => { 
                if (!listing) return;
            %>
                <div class="col mb-4">
                    <%- include('../includes/listingCard', { listing }) %>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<script>
    document.querySelectorAll(".wishlist-heart").forEach(icon => {
        icon.addEventListener("click", async (e) => {
            e.stopPropagation();
            e.preventDefault();

            const id = icon.dataset.id;
            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';

            await fetch(`/wishlist/toggle/${id}`, { 
                method: "POST",
                headers: { 
                    "Content-Type": "application/json",
                    "X-CSRF-Token": csrfToken,
                    "X-Requested-With": "XMLHttpRequest"
                }
            });

            icon.classList.toggle("fa-solid");
            icon.classList.toggle("fa-regular");
            icon.classList.toggle("saved");
        });
    });
</script>