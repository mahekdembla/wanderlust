<% layout("/layouts/boilerplate") -%>

    <%= success %>

    <% 
    const categoryVal = typeof category !== 'undefined' && category ? category : ''; 
    const recommendedVal = typeof recommended !== 'undefined' ? recommended : [];
    const trendingVal = typeof trending !== 'undefined' ? trending : [];
    const recentlyViewedVal = typeof recentlyViewed !== 'undefined' ? recentlyViewed : [];
    const popularNearbyVal = typeof popularNearby !== 'undefined' ? popularNearby : [];
    const highestRatedVal = typeof highestRated !== 'undefined' ? highestRated : [];
    const budgetFriendlyVal = typeof budgetFriendly !== 'undefined' ? budgetFriendly : [];
    const luxuryStaysVal = typeof luxuryStays !== 'undefined' ? luxuryStays : [];
    const newestListingsVal = typeof newestListings !== 'undefined' ? newestListings : [];
    %>

        <style>
            #filters {
                display: flex;
                flex-wrap: wrap;
                align-items: center;
                margin-bottom: 1.5rem;
            }

            .filter {
                text-align: center;
                margin-right: 2rem;
                margin-top: 2rem;
                opacity: 0.7;
                transition: opacity 0.2s ease;
                padding-bottom: 0.3rem;
            }

            .filter:hover {
                opacity: 1;
                cursor: pointer;
            }

            .filter.active {
                opacity: 1;
                border-bottom: 2px solid #fe424d;
                font-weight: bold;
            }

            .filter p {
                font-size: 0.8rem;
                margin-bottom: 0;
            }

            .tax-info {
                display: none;
            }

            .tax-toggle {
                border: 1px solid #ccc;
                border-radius: 1rem;
                height: 3.25rem;
                padding: 1rem;
                margin-left: auto;
                margin-top: 2rem;
                display: flex;
                align-items: center;
                background-color: #fff;
            }

            .wishlist-heart {
                position: absolute;
                top: 12px;
                right: 15px;
                font-size: 1.8rem;
                color: white;
                text-shadow: 0 0 5px black;
                cursor: pointer;
                z-index: 10;
            }

            .saved {
                color: red !important;
            }

            /* Horizontal Scroll System */
            .horizontal-scroll-row {
                display: flex;
                overflow-x: auto;
                gap: 1.5rem;
                padding: 0.5rem 0.2rem 1.5rem 0.2rem;
                scrollbar-width: none; /* Hide scrollbar Firefox */
            }
            
            .horizontal-scroll-row::-webkit-scrollbar {
                display: none; /* Hide scrollbar Chrome/Safari */
            }

            .scroll-card {
                flex: 0 0 280px; /* fixed width cards */
                transition: transform 0.22s cubic-bezier(0.2, 0.8, 0.2, 1);
            }

            .scroll-card:hover {
                transform: translateY(-4px) scale(1.01);
            }

            .section-title {
                font-weight: 600;
                color: #222;
                margin-top: 2rem;
                margin-bottom: 0.75rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .card-title {
                font-size: 1rem;
                line-height: 1.25;
            }

            .badge {
                font-size: 0.75rem;
            }
        </style>

        <div id="filters">
            <div class="filter <%= categoryVal === 'trending' ? 'active' : '' %>" data-category="trending"><i class="fa-solid fa-fire"></i>
                <p>trending</p>
            </div>
            <div class="filter <%= categoryVal === 'Rooms' ? 'active' : '' %>" data-category="Rooms"><i class="fa-solid fa-bed"></i>
                <p>Rooms</p>
            </div>
            <div class="filter <%= categoryVal === 'Iconic Cities' ? 'active' : '' %>" data-category="Iconic Cities"><i class="fa-solid fa-mountain-city"></i>
                <p>Iconic Cities</p>
            </div>
            <div class="filter <%= categoryVal === 'Mountains' ? 'active' : '' %>" data-category="Mountains"><i class="fa-solid fa-mountain"></i>
                <p>Mountains</p>
            </div>
            <div class="filter <%= categoryVal === 'Castles' ? 'active' : '' %>" data-category="Castles"><i class="fa-brands fa-fort-awesome"></i>
                <p>Castles</p>
            </div>
            <div class="filter <%= categoryVal === 'Amazing pools' ? 'active' : '' %>" data-category="Amazing pools"><i class="fa-solid fa-person-swimming"></i>
                <p>Amazing pools</p>
            </div>
            <div class="filter <%= categoryVal === 'Camping' ? 'active' : '' %>" data-category="Camping"><i class="fa-solid fa-campground"></i>
                <p>Camping</p>
            </div>
            <div class="filter <%= categoryVal === 'Farms' ? 'active' : '' %>" data-category="Farms"><i class="fa-solid fa-cow"></i>
                <p>Farms</p>
            </div>
            <div class="filter <%= categoryVal === 'Arctic' ? 'active' : '' %>" data-category="Arctic"><i class="fa-solid fa-snowflake"></i>
                <p>Arctic</p>
            </div>
            <div class="filter <%= categoryVal === 'Domes' ? 'active' : '' %>" data-category="Domes"><i class="fa-solid fa-igloo"></i>
                <p>Domes</p>
            </div>
            <div class="filter <%= categoryVal === 'Boats' ? 'active' : '' %>" data-category="Boats"><i class="fa-solid fa-ship"></i>
                <p>Boats</p>
            </div>

            <div class="tax-toggle">
                <div class="form-check-reverse form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" id="flexswitchCheckDefault">
                    <label class="form-check-label" for="flexswitchCheckDefault">Display Total after taxes</label>
                </div>
            </div>
        </div>

        <%
        // Define clean card template function
        const renderListingCard = (listing, isScroll = false) => {
        %>
            <div class="<%= isScroll ? 'scroll-card' : 'col mb-4' %>">
                <div class="card listing-card position-relative shadow-sm border-0 rounded-4 overflow-hidden h-100 bg-white">
                    <% if (currUser && currUser.savedListings.some(id => String(id) === String(listing._id))) { %>
                        <i class="fa-solid fa-heart wishlist-heart saved" data-id="<%= listing._id %>"></i>
                    <% } else { %>
                        <i class="fa-regular fa-heart wishlist-heart" data-id="<%= listing._id %>"></i>
                    <% } %>
                    <a href="/listings/<%= listing._id %>" class="listing-link">
                        <div class="listing-card-img-wrapper position-relative">
                            <img src="<%= (listing.images && listing.images.length > 0) ? listing.images[0].url : (listing.image ? listing.image.url : 'https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=400&q=80') %>" class="card-img-top" style="aspect-ratio: 4/3; object-fit: cover; width: 100%;" alt="<%= listing.title %>" loading="lazy">
                        </div>
                    </a>
                    <div class="card-body p-3">
                        <h6 class="card-title mb-1 text-truncate"><strong><%= listing.title %></strong></h6>
                        <p class="card-text text-muted mb-2 small"><i class="fa-solid fa-location-dot me-1 text-danger"></i><%= listing.location %></p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-dark small">
                                <% if (listing.listingType === "pg") { %>
                                    <strong>₹ <%= listing.pgDetails?.monthlyRent?.toLocaleString("en-IN") %></strong> / month
                                <% } else { %>
                                    <strong>₹ <%= listing.price?.toLocaleString("en-IN") %></strong> / night
                                <% } %>
                                <i class="tax-info text-muted text-opacity-70 small"> +18% GST</i>
                            </span>
                            <% if (listing.rating) { %>
                                <span class="badge bg-light text-dark border"><i class="fa-solid fa-star text-warning me-1"></i><%= listing.rating %></span>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- VIEW PANELS -->
        <% if (categoryVal) { %>
            
            <div class="d-flex justify-content-between align-items-center mt-3">
                <h4 class="fw-bold">Category Results: <%= categoryVal %></h4>
                <a href="/listings" class="btn btn-outline-dark btn-sm rounded-pill px-3">Clear Filter</a>
            </div>
            
            <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-4">
                <% if (allListings && allListings.length > 0) { %>
                    <% allListings.forEach(listing => { %>
                        <% renderListingCard(listing, false) %>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center py-5">
                        <div class="text-muted fs-5"><i class="fa-solid fa-circle-question me-2"></i>No listings found in <%= categoryVal %>.</div>
                    </div>
                <% } %>
            </div>

        <% } else { %>
            
            <%
            const hasAnyRecommendations = 
                (recommendedVal && recommendedVal.length > 0) || 
                (trendingVal && trendingVal.length > 0) || 
                (recentlyViewedVal && recentlyViewedVal.length > 0) || 
                (popularNearbyVal && popularNearbyVal.length > 0) || 
                (highestRatedVal && highestRatedVal.length > 0) || 
                (budgetFriendlyVal && budgetFriendlyVal.length > 0) || 
                (luxuryStaysVal && luxuryStaysVal.length > 0) || 
                (newestListingsVal && newestListingsVal.length > 0);
            %>

            <% if (hasAnyRecommendations) { %>
                
                <!-- 1. Recommended Listings -->
                <% if (recommendedVal && recommendedVal.length > 0) { %>
                    <h4 class="section-title">
                        <span>✨ Recommended For You</span>
                    </h4>
                    <div class="horizontal-scroll-row">
                        <% recommendedVal.forEach(listing => { %>
                            <% renderListingCard(listing, true) %>
                        <% }) %>
                    </div>
                <% } %>

                <!-- 2. Trending Listings -->
                <% if (trendingVal && trendingVal.length > 0) { %>
                    <h4 class="section-title">
                        <span>🔥 Trending Listings</span>
                        <a href="/listings?category=trending" class="btn btn-link text-decoration-none p-0 text-danger small">See All</a>
                    </h4>
                    <div class="horizontal-scroll-row">
                        <% trendingVal.forEach(listing => { %>
                            <% renderListingCard(listing, true) %>
                        <% }) %>
                    </div>
                <% } %>

                <!-- 3. Continue Exploring (Recently Viewed) -->
                <% if (recentlyViewedVal && recentlyViewedVal.length > 0) { %>
                    <h4 class="section-title">
                        <span>🕒 Continue Exploring</span>
                    </h4>
                    <div class="horizontal-scroll-row">
                        <% recentlyViewedVal.forEach(listing => { %>
                            <% renderListingCard(listing, true) %>
                        <% }) %>
                    </div>
                <% } %>

                <!-- 4. Popular Nearby -->
                <% if (popularNearbyVal && popularNearbyVal.length > 0) { %>
                    <h4 class="section-title">
                        <span>📍 Popular Nearby</span>
                    </h4>
                    <div class="horizontal-scroll-row">
                        <% popularNearbyVal.forEach(listing => { %>
                            <% renderListingCard(listing, true) %>
                        <% }) %>
                    </div>
                <% } %>

                <!-- 5. Highest Rated -->
                <% if (highestRatedVal && highestRatedVal.length > 0) { %>
                    <h4 class="section-title">
                        <span>⭐ Highest Rated stays</span>
                    </h4>
                    <div class="horizontal-scroll-row">
                        <% highestRatedVal.forEach(listing => { %>
                            <% renderListingCard(listing, true) %>
                        <% }) %>
                    </div>
                <% } %>

                <!-- 6. Budget Friendly -->
                <% if (budgetFriendlyVal && budgetFriendlyVal.length > 0) { %>
                    <h4 class="section-title">
                        <span>💰 Budget Friendly Picks</span>
                    </h4>
                    <div class="horizontal-scroll-row">
                        <% budgetFriendlyVal.forEach(listing => { %>
                            <% renderListingCard(listing, true) %>
                        <% }) %>
                    </div>
                <% } %>

                <!-- 7. Luxury Stays -->
                <% if (luxuryStaysVal && luxuryStaysVal.length > 0) { %>
                    <h4 class="section-title">
                        <span>💎 Luxury Stays</span>
                    </h4>
                    <div class="horizontal-scroll-row">
                        <% luxuryStaysVal.forEach(listing => { %>
                            <% renderListingCard(listing, true) %>
                        <% }) %>
                    </div>
                <% } %>

                <!-- 8. Newest Listings -->
                <% if (newestListingsVal && newestListingsVal.length > 0) { %>
                    <h4 class="section-title">
                        <span>🆕 New Listings</span>
                    </h4>
                    <div class="horizontal-scroll-row">
                        <% newestListingsVal.forEach(listing => { %>
                            <% renderListingCard(listing, true) %>
                        <% }) %>
                    </div>
                <% } %>

            <% } else { %>
                
                <!-- Fallback to standard listings grid if no recommendations are calculated (e.g. before server restarts) -->
                <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
                    <% if (typeof allListings !== 'undefined' && allListings && allListings.length > 0) { %>
                        <% allListings.forEach(listing => { %>
                            <% renderListingCard(listing, false) %>
                        <% }) %>
                    <% } %>
                </div>

            <% } %>

        <% } %>

        <script>
            // TAX TOGGLE
            document.getElementById("flexswitchCheckDefault")
                .addEventListener("click", () => {
                    document.querySelectorAll(".tax-info").forEach(x => {
                        x.style.display = x.style.display === "inline" ? "none" : "inline";
                    });
                });

            // Wishlist Toggle
            document.querySelectorAll(".wishlist-heart").forEach(icon => {
                icon.addEventListener("click", async (e) => {
                    e.stopPropagation();
                    e.preventDefault();

                    const id = icon.dataset.id;
                    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';
                    await fetch(`/wishlist/toggle/${id}`, { 
                        method: "POST",
                        headers: { "X-CSRF-Token": csrfToken }
                    });

                    icon.classList.toggle("fa-solid");
                    icon.classList.toggle("fa-regular");
                    icon.classList.toggle("saved");
                });
            });

            // Category filter click event redirect
            document.querySelectorAll(".filter").forEach(filter => {
                filter.addEventListener("click", () => {
                    const cat = filter.dataset.category;
                    if (cat) {
                        window.location.href = `/listings?category=${encodeURIComponent(cat)}`;
                    }
                });
            });
        </script>