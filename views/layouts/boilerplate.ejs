<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= locals.csrfToken || '' %>">
    <title>WanderLust</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.1/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <link href="/css/rating.css" rel="stylesheet" />

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        document.addEventListener("click", async (e) => {

            const heart = e.target.closest(".wishlist-icon");
            if (!heart) return;

            const listingId = heart.dataset.id;
            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';

            let res = await fetch(`/wishlist/toggle/${listingId}`, {
                method: "POST",
                headers: {
                    "X-Requested-With": "XMLHttpRequest",
                    "X-CSRF-Token": csrfToken
                }
            });

            let data = await res.json();

            if (data.saved) {
                heart.innerHTML = `<i class="fa-solid fa-heart saved"></i>`;
            } else {
                heart.innerHTML = `<i class="fa-regular fa-heart"></i>`;
            }
        });
    </script>


</head>

<body>
    <%- include("../includes/navbar.ejs")%>
        <div class="container">
            <%- include("../includes/flash.ejs")%>

                <%- body %>
        </div>
        <%- include("../includes/footer.ejs")%>

            <!-- Day.js relative time library CDN -->
            <script src="https://cdn.jsdelivr.net/npm/dayjs@1/dayjs.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/dayjs@1/plugin/relativeTime.js"></script>
            <script>
                if (typeof dayjs !== 'undefined') {
                    dayjs.extend(window.dayjs_plugin_relativeTime);
                }
            </script>

            <!-- Socket.io Client and Notifications Utility Setup -->
            <script src="/socket.io/socket.io.js"></script>
            <script>
                const currentUserId = "<%= locals.currUser ? locals.currUser._id : '' %>";
            </script>
            <script src="/js/notifications.js"></script>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
                integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
                crossorigin="anonymous"></script>
            <script src="/js/script.js"></script>

            <!-- Floating AI Trip Planner & Assistant Chatbot Widget -->
            <div id="ai-chat-bubble" class="shadow-lg d-flex justify-content-center align-items-center"
                style="position: fixed; bottom: 25px; right: 25px; width: 62px; height: 62px; background-color: #fe424d; color: white; border-radius: 50%; cursor: pointer; z-index: 9999; transition: transform 0.2s ease;">
                <i class="fa-solid fa-wand-magic-sparkles fs-3"></i>
            </div>

            <div id="ai-chat-window" class="shadow-lg border-0 rounded-4 overflow-hidden"
                style="display: none; position: fixed; bottom: 98px; right: 25px; width: 380px; height: 520px; background-color: white; z-index: 9999; flex-direction: column;">
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center p-3 text-white"
                    style="background-color: #fe424d;">
                    <h6 class="mb-0 fw-bold"><i class="fa-solid fa-plane-departure me-2"></i>AI Trip Planner & Assistant
                    </h6>
                    <span id="close-ai-chat" class="fs-4" style="cursor: pointer; line-height: 1;">&times;</span>
                </div>

                <!-- Messages Body -->
                <div id="ai-chat-messages" class="flex-grow-1 p-3 overflow-y-auto bg-light"
                    style="font-size: 0.88rem; height: 380px;">
                    <div class="mb-2 d-flex">
                        <div class="p-3 rounded-4 text-dark bg-white shadow-sm border border-light"
                            style="max-width: 88%;">
                            👋 Hi! I'm your <strong>Wanderlust AI Trip Planner</strong>.<br><br>
                            Ask me to <strong>plan a custom trip</strong> (e.g. <em>"Plan a 3-day trip to Goa for 6
                                people under 25000"</em>), estimate budgets, or suggest verified stays!
                        </div>
                    </div>
                </div>

                <!-- Input Form -->
                <form id="ai-chat-form" class="d-flex p-2 border-top bg-white m-0">
                    <input type="text" id="ai-chat-input" class="form-control rounded-pill me-2 border-1 px-3"
                        placeholder="Ask AI to plan a trip or suggest stays..." autocomplete="off"
                        style="font-size: 0.85rem;">
                    <button type="submit"
                        class="btn text-white rounded-circle d-flex justify-content-center align-items-center flex-shrink-0"
                        style="background-color: #fe424d; width: 38px; height: 38px; padding: 0;">
                        <i class="fa-solid fa-paper-plane small" style="font-size: 0.8rem;"></i>
                    </button>
                </form>
            </div>

            <script>
                const chatBubble = document.getElementById("ai-chat-bubble");
                const chatWindow = document.getElementById("ai-chat-window");
                const closeChat = document.getElementById("close-ai-chat");
                const chatForm = document.getElementById("ai-chat-form");
                const chatInput = document.getElementById("ai-chat-input");
                const chatMessages = document.getElementById("ai-chat-messages");

                let chatHistory = [];

                chatBubble.addEventListener("click", () => {
                    const isOpen = chatWindow.style.display === "flex";
                    chatWindow.style.display = isOpen ? "none" : "flex";
                    if (!isOpen) {
                        chatInput.focus();
                    }
                });

                closeChat.addEventListener("click", () => {
                    chatWindow.style.display = "none";
                });

                chatForm.addEventListener("submit", async (e) => {
                    e.preventDefault();
                    const text = chatInput.value.trim();
                    if (!text) return;

                    // Render user message
                    const userDiv = document.createElement("div");
                    userDiv.className = "mb-2 d-flex justify-content-end";
                    userDiv.innerHTML = `<div class="p-2 px-3 rounded-4 text-white shadow-sm" style="background-color: #fe424d; max-width: 85%;">${text}</div>`;
                    chatMessages.appendChild(userDiv);
                    chatInput.value = "";
                    chatMessages.scrollTop = chatMessages.scrollHeight;

                    // Render bot thinking loader
                    const thinkingDiv = document.createElement("div");
                    thinkingDiv.className = "mb-2 d-flex";
                    thinkingDiv.innerHTML = `<div class="p-2 px-3 rounded-4 text-muted bg-white shadow-sm border" style="max-width: 85%;"><i class="fa-solid fa-wand-magic-sparkles fa-spin me-2 text-danger"></i> Planning your trip...</div>`;
                    chatMessages.appendChild(thinkingDiv);
                    chatMessages.scrollTop = chatMessages.scrollHeight;

                    // Resolve context listing ID
                    const listingId = window.location.pathname.startsWith('/listings/') &&
                        !window.location.pathname.endsWith('/edit') &&
                        !window.location.pathname.endsWith('/new')
                        ? window.location.pathname.split('/')[2]
                        : null;

                    try {
                        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';
                        const res = await fetch("/ai/chat", {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                                "X-CSRF-Token": csrfToken,
                                "X-Requested-With": "XMLHttpRequest"
                            },
                            body: JSON.stringify({ message: text, listingId, history: chatHistory })
                        });
                        const data = await res.json();

                        thinkingDiv.remove();

                        if (data.success && data.reply) {
                            const botDiv = document.createElement("div");
                            botDiv.className = "mb-2 d-flex";

                            // Format response markdown strings with Bootstrap UI buttons
                            let rawContent = data.reply;
                            let formattedReply = rawContent
                                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                                .replace(/### (.*?)\n/g, '<h6 class="fw-bold mt-2 mb-1 text-danger border-bottom pb-1">$1</h6>')
                                .replace(/\[View Details & Book\]\((.*?)\)/g, '<a href="$1" class="btn btn-sm btn-danger rounded-pill px-3 py-1 me-1 my-1 text-white text-decoration-none shadow-sm fw-semibold" target="_blank"><i class="fa-solid fa-eye me-1"></i>View Details & Book Stays</a>')
                                .replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" class="text-danger fw-semibold text-decoration-none">$1</a>')
                                .replace(/\n/g, '<br>');

                            const headerBar = `
                                <div class="d-flex justify-content-between align-items-center border-bottom pb-1 mb-2">
                                    <span class="badge bg-danger rounded-pill"><i class="fa-solid fa-compass me-1"></i>Wanderlust AI 2.0</span>
                                    <div>
                                        <button type="button" class="btn btn-sm btn-light rounded-pill px-2 py-0 border me-1 small text-dark" onclick="const parent=this.closest('.chat-msg-card'); navigator.clipboard.writeText(parent.innerText); this.innerHTML='<i class=\\'fa-solid fa-check me-1\\'></i>Copied'; setTimeout(() => this.innerHTML='<i class=\\'fa-regular fa-copy me-1\\'></i>Copy', 2000);"><i class="fa-regular fa-copy me-1"></i>Copy</button>
                                        <button type="button" class="btn btn-sm btn-light rounded-pill px-2 py-0 border small text-dark" onclick="window.print()"><i class="fa-solid fa-print me-1"></i>Print</button>
                                    </div>
                                </div>`;

                            botDiv.innerHTML = `<div class="chat-msg-card p-3 rounded-4 text-dark bg-white shadow-sm border" style="max-width: 88%;">${headerBar}<div>${formattedReply}</div></div>`;
                            chatMessages.appendChild(botDiv);

                            chatHistory.push({ role: "user", text });
                            chatHistory.push({ role: "model", text: data.reply });
                        } else {
                            throw new Error(data.error || "Trip Assistant response failed");
                        }
                    } catch (err) {
                        thinkingDiv.remove();
                        const errDiv = document.createElement("div");
                        errDiv.className = "mb-2 d-flex";
                        errDiv.innerHTML = `<div class="p-2 px-3 rounded-4 text-danger bg-white shadow-sm border" style="max-width: 85%;"><i class="fa-solid fa-triangle-exclamation me-1"></i> ${err.message || "Failed to fetch response. Please try again."}</div>`;
                        chatMessages.appendChild(errDiv);
                    }
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                });
            </script>
</body>

</html>