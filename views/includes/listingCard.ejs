<% 
    // Reusable Listing Card Component
    const isSaved = (typeof currUser !== 'undefined' && currUser && currUser.savedListings && currUser.savedListings.some(id => String(id) === String(listing._id))) || (typeof isWishlist !== 'undefined' && isWishlist);
    const imgUrl = (listing.images && listing.images.length > 0) ? listing.images[0].url : (listing.image ? listing.image.url : 'https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=400&q=80');
%>

<div class="card listing-card position-relative shadow-sm border-0 rounded-4 overflow-hidden h-100 bg-white">
    <i class="fa-solid fa-heart wishlist-heart <%= isSaved ? 'saved' : '' %>" data-id="<%= listing._id %>" title="<%= isSaved ? 'Remove from Wishlist' : 'Add to Wishlist' %>"></i>

    <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="listing-card-img-wrapper position-relative">
            <img src="<%= imgUrl %>" class="card-img-top" alt="<%= listing.title %>" loading="lazy">
        </div>
    </a>

    <div class="card-body p-3 d-flex flex-column justify-content-between">
        <div>
            <h6 class="card-title mb-1" title="<%= listing.title %>"><strong><%= listing.title %></strong></h6>
            <p class="card-location text-muted mb-2 small"><i class="fa-solid fa-location-dot me-1 text-danger"></i><%= listing.location %></p>
        </div>
        <div class="card-footer-info d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
            <span class="price-tag small">
                <% if (listing.listingType === "pg") { %>
                    <strong>₹ <%= listing.pgDetails?.monthlyRent?.toLocaleString("en-IN") %></strong> / month
                <% } else { %>
                    <strong>₹ <%= listing.price?.toLocaleString("en-IN") %></strong> / night
                <% } %>
                <i class="tax-info text-muted text-opacity-70 small"> +18% GST</i>
            </span>
            <% if (listing.rating) { %>
                <span class="badge bg-light text-dark border"><i class="fa-solid fa-star text-warning me-1"></i><%= listing.rating %></span>
            <% } %>
        </div>
    </div>
</div>
